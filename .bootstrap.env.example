# ─── Fork bootstrap configuration ─────────────────────────────────────────────
#
# `make init` scaffolds this file from .bootstrap.env.example (gitignored).
# Fill in values, then run the forker journey:
#   make doctor          # validate config + probe Apple/GH; print done vs blocked
#   make bootstrap-fork  # idempotent: drive every programmatic step from this config
#   make ship            # trigger release (workflow_dispatch in CI mode, local lane in local mode)
#   make verify          # confirm TestFlight build appeared in App Store Connect
# Or run all four with `make all`.
#
# Sensitive values are referenced by file path (so the dotenv itself stays low-
# blast-radius). The actual secret bytes live in mode-0600 files outside the
# repo, typically under ~/.config/secrets/.
#
# Each `make doctor` run validates this config end-to-end. If it complains, fix
# the offending field and re-run — the doctor is idempotent and side-effect-free.

# ─── App identity ─────────────────────────────────────────────────────────────
# These end up in: scheme name, product name, CFBundleIdentifier, display
# name, project file name, IPA/PKG names, fastlane appfile, README, etc.

APP_NAME=YourApp                         # CamelCase. Becomes scheme + product.
BUNDLE_ID=com.your-org.yourapp           # iOS + macOS share the same bundle id.
DISPLAY_NAME='Your App'                  # CFBundleDisplayName (visible on home screen).
APP_EMAIL=you@example.com                # Maintainer email used in CHANGELOG, fastlane Appfile, etc.
GENERATOR=xcodegen                       # 'xcodegen' (default) or 'tuist'. Both manifests
                                         #   ship on `main`; this picks the one your fork uses.

# ─── Release mode ─────────────────────────────────────────────────────────────
# 'local' (default) — `make ship` runs fastlane release on this machine.
#                     Signing comes from the certs already in your login
#                     keychain (Apple Distribution + Apple Development + 3rd
#                     Party Mac Developer Installer; auto-minted by
#                     `make bootstrap-fork` if missing). Best for first-time
#                     shippers and solo developers.
# 'ci'              — `make ship` triggers .github/workflows/release.yml on
#                     the app repo (via gh CLI workflow_dispatch). The
#                     release runs on macos-15: each run mints fresh signing
#                     certs into a controlled keychain, ships, then revokes
#                     them. No certs repo. No PAT. Just ASC creds + a
#                     keychain password. Best for teams or release-from-
#                     anywhere setups.
RELEASE_MODE=local

# ─── Platforms ────────────────────────────────────────────────────────────────
# Which platforms this fork ships. Affects:
#   - `make doctor`: skips Mac-specific checks if PLATFORMS=ios (no Mac
#                    Installer cert probe, no .icns regeneration check)
#   - `make ship`: builds + uploads only the listed platforms
#   - `pr.yml`: skips iOS-only or Mac-only build jobs that don't match
#
# 'ios'        — iPhone/iPad only. Skips Mac signing + .pkg upload.
# 'macos'      — Mac only. Skips iOS signing + .ipa upload.
# 'ios,macos'  — both (default). Current shipping behavior.
#
# You can switch later: change this value, re-run `make bootstrap-fork`, and
# the relevant Mac or iOS pipeline pieces (de)activate. No tree mutation.
PLATFORMS=ios,macos

# ─── Submission behavior ──────────────────────────────────────────────────────
# When `make submit` runs, do you want fastlane to ALSO click "Submit for
# Review" on the staged version? Independent of staging — screenshots +
# metadata + build attachment + export-compliance answers are uploaded
# either way.
#
#   false (default) — STAGE only. Version sits in App Store Connect's
#                     "Prepare for Submission" state. Review the prepared
#                     listing in the ASC web UI, then click Submit
#                     yourself when satisfied. Recommended for early
#                     releases until you trust your screenshots / metadata
#                     / CHANGELOG pipeline. No GitHub Release is created
#                     until you actually submit.
#   true            — STAGE + auto-submit. Version goes to "Waiting for
#                     Review"; Apple's queue starts. Recommended once you
#                     trust the pipeline. A GitHub Release is published
#                     for the marketing version (notes from CHANGELOG.md).
#
# Per-invocation override (env wins over this field):
#   SUBMIT_FOR_REVIEW=true  make submit   # one-off auto-submit
#   SUBMIT_FOR_REVIEW=false make submit   # one-off stage when this says true
SUBMIT_FOR_REVIEW=false

# ─── Apple credentials ────────────────────────────────────────────────────────
# Get these from your Apple Developer account. The team id is at
# https://developer.apple.com/account/#/membership. The ASC API key is
# created at https://appstoreconnect.apple.com/access/api (App Manager role).

FASTLANE_TEAM_ID=                        # 10-char alphanumeric, e.g. A1B2C3D4E5
ASC_API_KEY_ID=                          # 10-char alphanumeric from the API Keys table
ASC_API_KEY_ISSUER_ID=                   # UUID format, shown above the table

# Path to the .p8 file you downloaded when you created the API key. Apple shows
# it once; if you lost it, generate a new key and revoke the old one.
ASC_API_KEY_P8_PATH=                     # e.g. ~/Downloads/AuthKey_AAAAAA1234.p8

# ─── GitHub identity ──────────────────────────────────────────────────────────
# The org/user that owns the app repo. GH_APP_REPO must already exist (you
# created it via `gh repo create --template` before running `make init`).
# `make bootstrap-fork` writes GH Secrets to this repo (CI mode only) and
# configures branch protection.

GH_ORG=                                  # e.g. your-org or your-username
GH_APP_REPO=                             # e.g. your-app — created via gh repo create --template

# ─── Keychain password (only used when RELEASE_MODE=ci) ──────────────────────
# Protects the controlled keychain that release.yml creates on the runner.
# If the file path below doesn't exist when `make bootstrap-fork` runs, a
# random 32-char value will be generated and written for you. If it already
# exists, the existing value is reused (so re-running bootstrap doesn't
# rotate it).

KEYCHAIN_PASSWORD_FILE=                  # e.g. ~/.config/secrets/keychain-password

# ─── Optional design assets ───────────────────────────────────────────────────
# If ICON_1024_PATH is set and points to a 1024×1024 PNG, `make bootstrap` will
# replace app/iOS/Assets.xcassets/AppIcon.appiconset/Icon-1024.png and
# regenerate the macOS .icns from it. Leave blank to keep the template's hammer
# stub icon (fine for TestFlight; not for App Store review).

ICON_1024_PATH=

# ─── App Store Connect App record ─────────────────────────────────────────────
# The ASC App record cannot be created via API (Apple disallows POST /apps).
# Create it manually at https://appstoreconnect.apple.com/apps before running
# `make bootstrap` — `bootstrap_asc` lane verifies it exists and fails loud
# with creation instructions otherwise.
#
# The SKU is anything unique (often the bundle id reversed, or a UUID). It
# isn't used for anything programmatic; you'll just see it in ASC reports.
#
# These two fields don't get used by `make bootstrap` directly — they're
# documentation hints for the human-gated step. Copy them into the ASC web
# UI form when you create the App.

ASC_APP_SKU=                             # e.g. yourapp-001
ASC_APP_NAME=                            # the human-readable App Store name; can equal DISPLAY_NAME

# ─── App Review contact (optional — env-first overrides file-tracked values) ──
# Apple's App Review needs a human to contact if there's a question about
# your binary. These fields populate the "App Review Information" section
# of every ASC submission. Resolution order at submit time (Fastfile's
# `read_review_field`):
#   1. APP_REVIEW_* env var below (recommended — keeps PII out of the
#      tracked template tree, especially relevant on public template forks).
#   2. fastlane/metadata/review_information/<name>.txt (legacy fallback).
#   3. Omitted from the submission — deliver errors with "<field> is
#      required" at submit time, instead of silently shipping placeholder
#      text (TODO, +10000000000) to Apple's review queue.
#
# To share these env vars across multiple forks (e.g. same reviewer across all
# your apps), export them from your shell profile (~/.zshrc, ~/.bashrc),
# a direnv .envrc per fork, or a secrets tool (1Password CLI / pass / etc.)
# rather than duplicating per-clone. The Fastfile reads ENV before falling
# back to file content for every cross-fork-eligible field.

APP_REVIEW_FIRST_NAME=                   # First name shown to Apple reviewers.
APP_REVIEW_LAST_NAME=                    # Last name shown to Apple reviewers.
APP_REVIEW_EMAIL=                        # Contact email — Apple writes here if review fails.
APP_REVIEW_PHONE=                        # E.164 phone, e.g. +14155551234.
APP_REVIEW_NOTES=                        # Free-form notes (test instructions, gotchas).

# ─── Demo account for App Review (apps with auth REQUIRE this) ────────────────
# Apple rejects any submission with a login screen unless reviewers can sign
# in. Provide a working long-lived demo account scoped to "App Review only"
# permissions in your auth backend. For no-auth apps, leave both blank.
#
# Storage: APP_REVIEW_DEMO_PASSWORD ends up as an env var in your dotenv.
# Keep `.bootstrap.env` mode 0600 (default for new files in most shells;
# verify with `ls -l`). Rotate the demo account whenever you rotate this
# file's contents.

APP_REVIEW_DEMO_USER=                    # Username/email reviewers log in with.
APP_REVIEW_DEMO_PASSWORD=                # Password for the demo account.

# ─── App Store metadata (optional — org-stable fields, env-first overrides) ───
# Apple requires a privacy URL, marketing URL, support URL, and copyright on
# every App Store listing. These are typically the same across every app a
# single org ships from this template — `https://yourorg.com/privacy`,
# `Copyright © 2026 Your Org`, etc. — so it's wasteful to fill them in every
# fork's `fastlane/metadata/en-US/*.txt`. Setting these env vars (via shell
# profile, .envrc, or your secrets tool) overrides the tracked file content
# at submit time. Resolution order in fastlane/Fastfile's `asc_field` lambda:
#   1. ASC_* env var below (recommended for org-stable values).
#   2. fastlane/metadata/en-US/<name>.txt (per-fork override; fork-only
#      surface for apps with privacy/support URLs that diverge from the
#      org default — e.g. a B2B app with a customer-specific privacy page).
#
# Per-app fields stay file-only because each fork's app must write unique
# content (description, keywords, subtitle, release_notes, name). Doctor's
# `ScanMetadata` step flags TODO/example.com placeholders for those.

ASC_PRIVACY_URL=                         # e.g. https://yourorg.com/privacy
ASC_SUPPORT_URL=                         # e.g. https://yourorg.com/support
ASC_MARKETING_URL=                       # e.g. https://yourorg.com — your app's marketing page (often = privacy URL parent).
ASC_COPYRIGHT=                           # e.g. Copyright © 2026 Your Org. All rights reserved.

# ─── App Store primary locale + category (optional) ───────────────────────────
# ASC_PRIMARY_LOCALE: overrides the en-US default for orgs whose primary App
# Store market isn't English. The .txt files are expected at
# `fastlane/metadata/<locale>/*.txt` — same path shape, different subdir
# name. To switch a fork: set this env, rename `fastlane/metadata/en-US/`
# to `fastlane/metadata/<locale>/`, translate the content. Most forks leave
# this blank (en-US wins).
#
# ASC_PRIMARY_CATEGORY / ASC_SECONDARY_CATEGORY: only passed to deliver when
# set non-empty, so the ASC App Record's existing category (chosen when the
# App was created in ASC) wins by default. Set to change categories without
# clicking through the ASC web UI. Apple's accepted values are documented at
# https://developer.apple.com/help/app-store-connect/reference/app-categories;
# the english label is what deliver expects (e.g. `Productivity`, not the
# internal id `productivity`). Sub-categories (game-app-specific) are not
# yet plumbed; add them to fastlane/Fastfile's deliver_args when needed.

ASC_PRIMARY_LOCALE=                      # e.g. fr-FR. Default: en-US.
ASC_PRIMARY_CATEGORY=                    # e.g. Productivity, Developer Tools, Business.
ASC_SECONDARY_CATEGORY=                  # e.g. Utilities. Optional; omit to leave unset.

# ─── TestFlight Export Compliance (optional) ──────────────────────────────────
# Apple requires every TestFlight build to answer the Export Compliance
# question (Info.plist `ITSAppUsesNonExemptEncryption` or ASC web UI prompt)
# before App Review will accept it. When this env is set, fastlane patches
# the just-uploaded build's `usesNonExemptEncryption` via App Store Connect
# API during the annotate step — no more "answer this question" prompt on
# every TestFlight upload.
#
# Apple's exempt list: HTTPS, SSL/TLS, standard library encryption. Most
# template-derived apps qualify (`false` is the safe default). Apps doing
# custom crypto — E2EE messengers, custom protocols, embedded crypto
# libraries — must declare `true` and register with the U.S. Bureau of
# Industry & Security per https://developer.apple.com/help/app-store-connect/manage-app-information/encryption-export-regulations.
#
# When unset: fastlane skips the patch; the forker answers via ASC web UI
# per build (the pre-PR behavior — safe-additive).

ASC_USES_NON_EXEMPT_ENCRYPTION=          # "false" (HTTPS-only — typical) or "true" (custom crypto).

# ─── TestFlight Beta App information (optional) ───────────────────────────────
# App-wide TestFlight fields shown to beta testers in the TestFlight app.
# All four are typically org-stable across every app a single shipper
# ships — same feedback email, same privacy policy URL, same marketing
# page — so consider exporting them from your shell profile / .envrc.
# Each env is patched independently; unset envs leave ASC's existing
# value untouched.
#
# Apple requires `privacyPolicyUrl` on every TestFlight app before
# external testers can invite-link install. `feedbackEmail` shows up as
# the "Send Feedback" target in the TestFlight app. `description` is the
# multi-paragraph blurb beta testers read before installing.

BETA_APP_DESCRIPTION=                    # Multi-line description for TestFlight testers.
BETA_APP_FEEDBACK_EMAIL=                 # e.g. testflight@yourorg.com
BETA_APP_MARKETING_URL=                  # Optional. Often = ASC_MARKETING_URL.
BETA_APP_PRIVACY_URL=                    # REQUIRED for external testers. Often = ASC_PRIVACY_URL.

# ─── App Privacy form acknowledgement (optional) ──────────────────────────────
# Apple requires every app submitted to the App Store to publish the
# "App Privacy" form in App Store Connect (web UI: your app → App Privacy
# → Edit). The form declares what data your app collects, why, whether
# each data type is linked to user identity, and whether any is used for
# tracking. Most template forks declare "Data Not Collected" since they
# don't link analytics SDKs, ad networks, or trackers — but Apple validates
# against your binary's ACTUAL SDK usage, so mismatches trigger App Review
# rejection. We don't plumb the form through dotenv (the schema changes
# every year, the categories are app-specific, and a wrong declaration is
# worse than no declaration), but doctor surfaces its publish-state.
#
# Set to "true" once you've published the form in the ASC web UI to
# silence the doctor warning. Useful for forks that have published the
# form but don't want doctor probing Apple's API on every run, or for
# offline validation cycles.
#
# Apple ref: https://developer.apple.com/help/app-store-connect/manage-app-information/manage-app-privacy

ASC_APP_PRIVACY_ACK=                     # "true" to suppress doctor's App-Privacy-unpublished warning.
