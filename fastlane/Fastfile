# fastlane/Fastfile
#
# iOS + macOS release pipeline. Modeled on production iOS + macOS shipping
# pipelines used in real App Store submissions.
#
# Usage:
#   make ship   # auto-exports env from .bootstrap.env, then invokes fastlane release tag:v0.1.0
#
# Dry run (no upload, no tag push):
#   fastlane release tag:v0.1.0 skip_upload:true skip_tag:true
#
# What `release` does:
#   1. Build signed iOS .ipa + macOS .pkg via ci/local-release-check.sh
#   2. Upload iOS .ipa to TestFlight (`pilot`)
#   3. Upload macOS .pkg to TestFlight (`pilot`)
#   4. Push the git tag (triggers .github/workflows/release.yml if present)
#
# Prerequisites:
#   - Distribution cert + iOS provisioning profile in login Keychain
#   - macOS provisioning profile + Mac Installer Distribution cert
#   - .bootstrap.env with ASC_API_KEY_ID, ASC_API_KEY_ISSUER_ID, ASC_API_KEY_P8_PATH,
#     FASTLANE_TEAM_ID
#
# Per-platform metadata + submission lanes:
#   fastlane ios upload_metadata     # update iOS App Store record
#   fastlane mac upload_metadata     # update macOS App Store record
#   fastlane ios upload_screenshots  # iOS screenshots
#   fastlane mac upload_screenshots  # macOS screenshots
#   fastlane ios submit_for_review   # submit iOS for App Review
#   fastlane mac submit_for_review   # submit macOS for App Review
#
# Single-command "bump everything for new version":
#   ci/bump-asc-version.sh v0.1.0    # screenshots + version bump + metadata + screenshots

default_platform(:ios)

# In CI: provision a temporary keychain for match (via setup_ci) and switch
# match to readonly mode. Locally: no-op. Always: ensure ASC API token is set
# so any Spaceship calls (BundleId.create, App.create, Certificate.delete)
# authenticate without 2FA.
before_all do
  setup_ci if ENV["CI"]
  asc_api_key
end

# ─── Shared helpers ───────────────────────────────────────────────────────────

APP_IDENTIFIER     = "com.example.helloapp"
IOS_SCHEME         = "HelloApp-iOS"
MACOS_SCHEME       = "HelloApp-macOS"
IPA_NAME_PATTERN   = "HelloApp-%s.ipa"   # printf with version
PKG_NAME_PATTERN   = "HelloApp-%s.pkg"

def asc_api_key
  # Decode .p8 to a tmpfile and pass key_filepath instead of key_content +
  # is_key_content_base64. The latter route hits a fastlane 2.233.x bug on
  # macos-15 + Ruby 3.3.11 + OpenSSL 3.6.x where Token.create raises
  # "OpenSSL::PKey::ECError: invalid curve name" inside the action wrapper
  # (despite Spaceship::ConnectAPI::Token.create succeeding when called
  # directly with the same args). The file path route bypasses the buggy
  # gsub + Base64.decode64 path inside the action. See
  # docs/CONTINUOUS-VALIDATION.md G11.
  require "base64"
  require "tmpdir"
  @asc_p8_path ||= begin
    path = File.join(Dir.tmpdir, "asc_api_key_#{ENV.fetch('ASC_API_KEY_ID')}.p8")
    File.write(path, Base64.decode64(ENV.fetch("ASC_API_KEY_P8_BASE64")))
    File.chmod(0600, path)
    # Wipe the decoded .p8 on process exit. Doesn't survive crashes but
    # covers normal exits including UI.user_error!.
    at_exit do
      File.unlink(path) if File.exist?(path)
    rescue StandardError
      # Best-effort; don't blow up the exit path if the file is already
      # gone or unwritable.
    end
    path
  end
  app_store_connect_api_key(
    key_id:       ENV["ASC_API_KEY_ID"],
    issuer_id:    ENV["ASC_API_KEY_ISSUER_ID"],
    key_filepath: @asc_p8_path
  )
end

# Wraps `pilot(...)` in retry-with-exponential-backoff. ASC's altool upload
# step is the most flake-prone in the pipeline (transient TLS resets, slow
# Apple-side processing, sporadic 503s). Without retry, a single transient
# failure on the macOS upload (after iOS already uploaded) leaves the
# release in a half-shipped state with the tag unpushed — most painful when
# diagnosing days later.
#
# Mirrors ci/local-release-check.sh's with_timestamp_retry pattern.
def pilot_with_retry(opts, max_attempts: 3)
  attempts = 0
  begin
    attempts += 1
    pilot(**opts)
  rescue StandardError => e
    if attempts < max_attempts
      delay = 2**attempts # 2s, 4s, 8s
      UI.important("pilot upload failed (attempt #{attempts}/#{max_attempts}): #{e.message.lines.first&.strip}")
      UI.important("retrying in #{delay}s…")
      sleep(delay)
      retry
    end
    UI.error("pilot upload failed after #{max_attempts} attempts. Last error:")
    UI.error(e.message)
    raise
  end
end

# Reads every metadata file directly and passes explicit hashes to deliver.
# Bypasses deliver's load_from_filesystem, which silently drops fields when
# metadata_path is passed alone (we've reproduced this for support_url,
# marketing_url, copyright, name, subtitle, privacy_url across multiple
# fastlane versions).
#
# `platform:` should be :ios or :osx (deliver's spelling).
def do_upload_metadata(platform:)
  metadata_dir    = File.join(__dir__, "metadata")
  en_us_dir       = File.join(metadata_dir, "en-US")
  review_info_dir = File.join(metadata_dir, "review_information")

  review_info = {
    first_name:    File.read(File.join(review_info_dir, "first_name.txt")).strip,
    last_name:     File.read(File.join(review_info_dir, "last_name.txt")).strip,
    email_address: File.read(File.join(review_info_dir, "email_address.txt")).strip,
    notes:         File.read(File.join(review_info_dir, "notes.txt")).strip,
  }
  phone_path = File.join(review_info_dir, "phone_number.txt")
  if File.exist?(phone_path)
    phone = File.read(phone_path).strip
    review_info[:phone_number] = phone unless phone.start_with?("TODO")
  end

  en_us  = ->(name) { File.read(File.join(en_us_dir, "#{name}.txt")).strip }
  locale = "en-US"

  deliver(
    api_key:                  asc_api_key,
    app_identifier:           APP_IDENTIFIER,
    platform:                 platform.to_s,
    metadata_path:            metadata_dir,
    app_review_information:   review_info,
    name:                     { locale => en_us.call("name") },
    subtitle:                 { locale => en_us.call("subtitle") },
    privacy_url:              { locale => en_us.call("privacy_url") },
    description:              { locale => en_us.call("description") },
    keywords:                 { locale => en_us.call("keywords") },
    support_url:              { locale => en_us.call("support_url") },
    marketing_url:            { locale => en_us.call("marketing_url") },
    release_notes:            { locale => en_us.call("release_notes") },
    copyright:                File.read(File.join(metadata_dir, "copyright.txt")).strip,
    skip_metadata:            false,
    skip_binary_upload:       true,
    skip_screenshots:         true,
    force:                    true,
    submit_for_review:        false,
    automatic_release:        false,
    precheck_include_in_app_purchases: false
  )
  if review_info[:phone_number].nil?
    UI.success("Metadata uploaded. (Phone number for review still pending — fill fastlane/metadata/review_information/phone_number.txt before submit_for_review.)")
  else
    UI.success("Metadata uploaded.")
  end
end

def do_submit_for_review(platform:)
  deliver(
    api_key:                  asc_api_key,
    app_identifier:           APP_IDENTIFIER,
    platform:                 platform.to_s,
    skip_metadata:            false,
    skip_binary_upload:       true,
    skip_screenshots:         false,
    force:                    true,
    submit_for_review:        true,
    automatic_release:        false,
    submission_information: {
      export_compliance_uses_encryption: false,
      export_compliance_encryption_updated: false,
      add_id_info_uses_idfa: false,
      content_rights_contains_third_party_content: false,
    },
    precheck_include_in_app_purchases: false
  )
  UI.success("Submitted to App Review (#{platform}).")
end

# ─── App ID + ASC bootstrap ───────────────────────────────────────────────────

desc "Register App ID in Apple Developer Portal (idempotent)"
desc "Used once locally before fastlane match runs. ASC app record (TestFlight"
desc "/ App Store side) is created later via the bootstrap_asc lane."
lane :register_app_id do
  asc_api_key  # sets Spaceship::ConnectAPI.token globally

  bundle_id_str = APP_IDENTIFIER
  bundle_name   = "HelloApp"

  existing = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: bundle_id_str }).first

  if existing
    UI.success("App ID #{bundle_id_str} already registered (id=#{existing.id}, platform=#{existing.platform})")
  else
    # platform: IOS — match's --platform macos path will register the
    # macOS bundle ID separately when generating the macOS provisioning
    # profile. (BundleIdPlatform::UNIVERSAL is not exposed by spaceship
    # in fastlane 2.230 even though Apple's API supports it.)
    created = Spaceship::ConnectAPI::BundleId.create(
      name:       bundle_name,
      identifier: bundle_id_str,
      platform:   Spaceship::ConnectAPI::BundleIdPlatform::IOS,
    )
    UI.success("App ID #{bundle_id_str} registered: id=#{created.id} (IOS)")
  end
end

desc "Enumerate all certificates in the team (debug helper)"
lane :list_certs do
  asc_api_key
  certs = Spaceship::ConnectAPI::Certificate.all
  UI.message("#{certs.length} certificate(s) in team:")
  certs.each do |c|
    UI.message("  #{c.id} type=#{c.certificate_type} display='#{c.display_name}' expires=#{c.expiration_date}")
  end
end

desc "Revoke a certificate by ASC certificate ID (one-time cleanup)"
desc "Usage: fastlane revoke_cert id:XN82HWM7L8"
lane :revoke_cert do |options|
  cert_id = options[:id] or UI.user_error!("id: required (ASC certificate ID)")
  asc_api_key

  cert = Spaceship::ConnectAPI::Certificate.all.find { |c| c.id == cert_id }
  UI.user_error!("Certificate #{cert_id} not found in team") unless cert

  UI.message("Revoking #{cert.id} type=#{cert.certificate_type} expires=#{cert.expiration_date}")
  Spaceship::ConnectAPI.delete_certificate(certificate_id: cert.id)
  UI.success("Revoked #{cert.id}")
end

desc "Idempotently verify Dev Portal App ID + ASC App record exist."
desc ""
desc "Calls register_app_id (creates the Dev Portal App ID via Spaceship if"
desc "missing), then verifies the App Store Connect App record exists. The"
desc "ASC App record CANNOT be created via API key — Apple's public ASC API"
desc "exposes only GET/UPDATE on /apps, never POST. fastlane's `produce`"
desc "action falls back to Apple-ID + 2FA login for app creation, which we"
desc "deliberately don't carry in CI secrets. So this lane verifies and"
desc "fails fast with instructions if the App is missing — a one-time"
desc "human step against appstoreconnect.apple.com unblocks all future"
desc "automated runs."
lane :bootstrap_asc do
  # 1. Ensure App ID exists in Apple Developer Portal (idempotent; uses
  #    Spaceship::ConnectAPI::BundleId which DOES allow POST).
  register_app_id

  # 2. Verify ASC App record exists (TestFlight / App Store side).
  bundle_id_str = APP_IDENTIFIER
  existing = Spaceship::ConnectAPI::App.find(bundle_id_str)

  if existing
    UI.success("ASC app for #{bundle_id_str} exists (id=#{existing.id}).")
  else
    # `return` inside a fastlane lane block is a LocalJumpError. UI.user_error!
    # raises FastlaneError, which fastlane catches and prints — same end result
    # as a hard failure but compatible with the lane DSL.
    UI.user_error!(<<~MSG)
      ASC App record for #{bundle_id_str} not found.

      The App Store Connect API does not allow POST /apps. Create the App
      once via the web UI:

        1. https://appstoreconnect.apple.com/apps  →  + (New App)
        2. Platforms: iOS + macOS
           Name:      HelloApp  (or whatever; verify uses bundle_id, not name)
           Primary language: English (U.S.)
           Bundle ID: #{bundle_id_str}
           SKU:       any-unique-string
           User Access: Full Access
        3. Re-run this lane — it will succeed and never block again.

      Apple ref: https://developer.apple.com/documentation/appstoreconnectapi/apps
      fastlane workaround (produce) requires Apple ID + 2FA, which we
      deliberately don't carry in CI. One-time human step is the cleanest path.
    MSG
  end
end

desc "Run match readonly:false against all 3 cert types (one-time bootstrap)."
desc ""
desc "Wraps the 3 raw `fastlane match` invocations from the README's signing"
desc "setup so before_all runs once and the ASC API key is loaded for every"
desc "call. Without this lane, raw `fastlane match appstore --app_identifier"
desc "...` from the CLI hits 'Missing username, and running in non-interactive"
desc "shell' because it skips before_all. After running this lane once, the"
desc "release pipeline (which only does match readonly:true) finds everything"
desc "in the certs repo and never has to mint."
desc ""
desc "Run after editing fastlane/Matchfile (git_url) and setting the 7 GH"
desc "Secrets / .bootstrap.env. The Mac Installer Distribution cert is bootstrapped"
desc "separately via bin/mint-installer-cert.rb + bin/import-installer-to-match.rb"
desc "(see Matchfile header for why)."
lane :bootstrap_certs do
  unless File.exist?(File.join(__dir__, "Matchfile"))
    UI.user_error!("fastlane/Matchfile not found. Edit + commit it first (replace CHANGE-ME-ORG/CHANGE-ME-REPO-certs.git).")
  end

  # Also fail fast if the Matchfile still has the placeholder text. Without
  # this check, match would later try to clone CHANGE-ME-ORG/CHANGE-ME-REPO
  # and the failure surfaces 30+ lines into match's git output, not actionable.
  matchfile_text = File.read(File.join(__dir__, "Matchfile"))
  if matchfile_text.include?("CHANGE-ME-")
    UI.user_error!(<<~MSG)
      fastlane/Matchfile still contains 'CHANGE-ME-' placeholder text.
      Edit it to point at your private certs repo (git_url, etc.) before
      running this lane. See README → "Optional: enable CI signing via
      fastlane match" for the full setup.
    MSG
  end

  match(type: "appstore",    app_identifier: APP_IDENTIFIER, platform: "ios")
  match(type: "appstore",    app_identifier: APP_IDENTIFIER, platform: "macos")
  match(type: "development", app_identifier: APP_IDENTIFIER, platform: "ios")

  UI.success(<<~MSG)
    bootstrap_certs done. Now run:
      bundle exec ruby bin/mint-installer-cert.rb
      export INSTALLER_CERT_ID=<id-printed-by-mint-script>
      bundle exec ruby bin/import-installer-to-match.rb
    See README "Optional: enable CI signing via fastlane match" for the full sequence.
  MSG
end

# ─── iOS lanes ────────────────────────────────────────────────────────────────
platform :ios do
  desc "Sign + upload to TestFlight + push tag"
  desc "Usage:    fastlane release tag:v0.1.0"
  desc "Dry run:  fastlane release tag:v0.1.0 skip_upload:true skip_tag:true"
  lane :release do |options|
    tag         = options[:tag] or UI.user_error!("tag: option is required (e.g. tag:v0.1.0)")
    skip_upload = options[:skip_upload] || false
    skip_tag    = options[:skip_tag]    || false

    repo_root = File.expand_path("..", __dir__)
    version   = tag.sub(/^v/, "")
    dry_run   = skip_upload || skip_tag

    # PLATFORMS gates which targets get built/signed/uploaded.
    # Set via .bootstrap.env's PLATFORMS field (defaults to 'ios,macos').
    # Threaded into this lane via release.yml's `PLATFORMS` env var (CI mode)
    # or bin/ship.rb's local-mode env (local mode). Empty/unset → both.
    raw_platforms = (ENV["PLATFORMS"].to_s.strip.empty? ? "ios,macos" : ENV["PLATFORMS"])
    active_platforms = raw_platforms.split(",").map(&:strip).reject(&:empty?)
    do_ios   = active_platforms.include?("ios")
    do_macos = active_platforms.include?("macos")
    UI.user_error!("PLATFORMS must include at least one of 'ios' or 'macos' (got #{raw_platforms.inspect})") unless do_ios || do_macos

    UI.header("Release #{tag}#{dry_run ? " [DRY RUN]" : ""} — platforms: #{active_platforms.join('+')}")

    # When fastlane/Matchfile exists, sync signing material from your certs
    # repo BEFORE invoking xcodebuild — this is what enables CI signing without
    # an Apple ID logged in. readonly: true → CI never mints new certs/profiles;
    # we only consume what`s already in the certs repo. The release lane reads
    # match`s emitted profile-name env vars and threads them into the script,
    # which switches xcodebuild to MANUAL signing (avoids "Cloud signing
    # permission error" during exportArchive — automatic signing tries Apple`s
    # cloud-signing endpoint which API-key auth cant access).
    #
    # When Matchfile is absent (e.g. you haven`t configured match yet), the lane
    # falls through to the legacy automatic-signing path: requires Xcode logged
    # into Apple ID + cert/profile in login.keychain. Works locally, fails in CI.
    matchfile_present = File.exist?(File.join(__dir__, "Matchfile"))
    sh_env            = {}

    if matchfile_present
      bits = []
      bits << "iOS"               if do_ios
      bits << "macOS"             if do_macos
      bits << "macOS installer"   if do_macos
      UI.message("Step 1/5: syncing signing material via match (#{bits.join(' + ')})…")
      if do_ios
        match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: true,
              platform: "ios", api_key: asc_api_key)
      end
      if do_macos
        match(type: "appstore", app_identifier: APP_IDENTIFIER, readonly: true,
              platform: "macos", api_key: asc_api_key)
        # macOS .pkg requires a separate "Mac Installer Distribution" cert
        # (productbuild signs the .pkg installer wrapper with this — distinct
        # from the Apple Distribution cert that signs the .app inside).
        match(type: "mac_installer_distribution", app_identifier: APP_IDENTIFIER,
              readonly: true, platform: "macos", skip_provisioning_profiles: true,
              api_key: asc_api_key)
      end

      # match's profile names include a timestamp suffix per generation
      # (e.g. "match AppStore com.example.helloapp 1778027568") — read from
      # the env vars match emits at runtime; do NOT hardcode.
      sh_env = { "RELEASE_BUNDLE_ID" => APP_IDENTIFIER }
      if do_ios
        ios_profile_name = ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"]
        UI.user_error!("match didn't set sigh_#{APP_IDENTIFIER}_appstore_profile-name — did the iOS match call run?") unless ios_profile_name
        sh_env["RELEASE_IOS_PROFILE_NAME"] = ios_profile_name
      end
      if do_macos
        macos_profile_name = ENV["sigh_#{APP_IDENTIFIER}_appstore_macos_profile-name"]
        UI.user_error!("match didn't set sigh_#{APP_IDENTIFIER}_appstore_macos_profile-name — did the macOS match call run?") unless macos_profile_name
        sh_env["RELEASE_MACOS_PROFILE_NAME"] = macos_profile_name
      end
    else
      UI.message("Step 1/5: no fastlane/Matchfile — skipping match sync. Using local Xcode-managed signing.")
    end

    sign_flags = []
    sign_flags << "--sign-ios"   if do_ios
    sign_flags << "--sign-macos" if do_macos
    UI.message("Step 2/5: building signed artifacts (#{sign_flags.join(' ')}) for v#{version}…")
    sh(sh_env, "cd #{repo_root} && ci/local-release-check.sh #{tag} #{sign_flags.join(' ')}")

    ipa_path = File.join(repo_root, "build", IPA_NAME_PATTERN % version)
    pkg_path = File.join(repo_root, "build", PKG_NAME_PATTERN % version)
    if do_ios
      UI.user_error!("IPA missing at #{ipa_path}") unless File.exist?(ipa_path)
    end
    if do_macos
      UI.user_error!("pkg missing at #{pkg_path}") unless File.exist?(pkg_path)
    end

    api_key = asc_api_key

    if skip_upload
      UI.important("Step 3/5: Skipping iOS TestFlight upload (skip_upload:true)")  if do_ios
      UI.important("Step 4/5: Skipping macOS TestFlight upload (skip_upload:true)") if do_macos
    else
      if do_ios
        UI.message("Step 3/5: Uploading iOS .ipa to TestFlight…")
        pilot_with_retry(api_key: api_key, ipa: ipa_path, skip_waiting_for_build_processing: true)
      end
      if do_macos
        UI.message("Step 4/5: Uploading macOS .pkg to TestFlight…")
        pilot_with_retry(api_key: api_key, pkg: pkg_path, skip_waiting_for_build_processing: true)
      end
    end

    if skip_tag
      UI.important("Step 5/5: Skipping tag push (skip_tag:true). Run 'git tag #{tag} && git push origin #{tag}' manually when ready.")
    else
      UI.message("Step 5/5: Tagging and pushing #{tag}…")
      sh("cd #{repo_root} && git tag #{tag} && git push origin #{tag}")
    end

    UI.success("#{tag} is live on TestFlight (#{active_platforms.join(' + ')}).")
  end

  desc "Capture App Store screenshots (iOS + macOS via ci/take-screenshots.sh)"
  desc "Output: fastlane/screenshots/en-US/*.png"
  desc "Usage: fastlane take_screenshots"
  # Renamed from `capture_screenshots` to avoid the lane-vs-built-in-action collision.
  lane :take_screenshots do
    repo_root = File.expand_path("..", __dir__)
    sh("cd #{repo_root} && ci/take-screenshots.sh")
    UI.success("Screenshots in fastlane/screenshots/. Inspect, then run upload_screenshots (ios/mac).")
  end

  desc "Upload iOS screenshots to App Store Connect (no submit, no metadata change)"
  lane :upload_screenshots do
    deliver(
      api_key:                  asc_api_key,
      app_identifier:           APP_IDENTIFIER,
      platform:                 :ios,
      skip_metadata:            true,
      skip_binary_upload:       true,
      skip_screenshots:         false,
      overwrite_screenshots:    true,
      force:                    true,
      submit_for_review:        false,
      automatic_release:        false,
      precheck_include_in_app_purchases: false
    )
    UI.success("iOS screenshots uploaded. Submit via fastlane ios submit_for_review when ready.")
  end

  desc "Upload iOS metadata text (name/subtitle/description/keywords/URLs) without screenshots or binary"
  lane :upload_metadata do
    do_upload_metadata(platform: :ios)
  end

  desc "Submit the latest iOS TestFlight build for App Store review"
  desc "Prerequisites: take_screenshots + upload_screenshots + upload_metadata done; build is in 'Ready for Review' state"
  lane :submit_for_review do
    do_submit_for_review(platform: :ios)
  end
end

# ─── macOS lanes ──────────────────────────────────────────────────────────────
# iOS + macOS apps share the same bundle id (Universal Purchase). App Store
# Connect maintains separate AppStoreVersion records per platform — the same
# metadata files are reused across both platforms by default.
platform :mac do
  desc "Upload macOS metadata text"
  lane :upload_metadata do
    do_upload_metadata(platform: :osx)
  end

  desc "Upload macOS screenshots in fastlane/screenshots/en-US/ to App Store Connect"
  # deliver infers macOS device class from PNG dimensions
  # (2880×1800 → MAC_2880, 1440×900 → MAC_1440, etc.).
  lane :upload_screenshots do
    deliver(
      api_key:                  asc_api_key,
      app_identifier:           APP_IDENTIFIER,
      platform:                 "osx",
      skip_metadata:            true,
      skip_binary_upload:       true,
      skip_screenshots:         false,
      overwrite_screenshots:    true,
      force:                    true,
      submit_for_review:        false,
      automatic_release:        false,
      precheck_include_in_app_purchases: false
    )
    UI.success("macOS screenshots uploaded. Submit via fastlane mac submit_for_review when ready.")
  end

  desc "Submit the latest macOS TestFlight build for App Store review"
  lane :submit_for_review do
    do_submit_for_review(platform: :osx)
  end
end
