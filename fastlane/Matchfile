# fastlane/Matchfile — fastlane match config.
#
# Match stores AES-256-CBC-encrypted distribution + development certificates
# and provisioning profiles in a private git repo. Both your laptop and CI
# consume from there.
#
# Required env vars (set in your shell for local match runs; set as GH Secrets
# for CI):
#   MATCH_PASSWORD                 — encryption passphrase for the certs repo
#   MATCH_GIT_BASIC_AUTHORIZATION  — base64(<gh-user>:<PAT>) for HTTPS clone
#   ASC_API_KEY_ID                 — ASC API key ID
#   ASC_API_KEY_ISSUER_ID          — ASC API key issuer UUID
#   ASC_API_KEY_P8_BASE64          — base64-encoded contents of the .p8 file
#   FASTLANE_TEAM_ID               — Apple Developer team ID
#
# Local first-run sequence (one-time, on a maintainer's Mac):
#   bundle exec fastlane match appstore --app_identifier com.example.helloapp
#   bundle exec fastlane match appstore --app_identifier com.example.helloapp --platform macos
#   bundle exec fastlane match development --app_identifier com.example.helloapp
#   # Then for the macOS .pkg installer cert (separate cert type, see bin/mint-installer-cert.rb):
#   ./bin/mint-installer-cert.rb && ./bin/import-installer-to-match.rb
#
# CI consumption (release.yml lane runs all 3 readonly):
#   match appstore --readonly --platform ios
#   match appstore --readonly --platform macos
#   match mac_installer_distribution --readonly --platform macos
#
# Annual rotation (when ASC API key, MATCH_PASSWORD, or PAT need refresh):
#   bundle exec fastlane match nuke distribution
#   bundle exec fastlane match appstore --app_identifier com.example.helloapp
#   (...and macOS counterpart...)
#
# Setting up the certs repo (one-time, before any of the above):
#   1. Create a NEW PRIVATE git repo. Convention: <your-app-repo>-certs.
#      Example: github.com/<your-org>/<your-repo>-certs.
#   2. Set the URL below.
#   3. Generate MATCH_PASSWORD (32+ char random) — store in your local
#      ~/.config/secrets.env (mode 0600) AND as a GH Secret.
#   4. Generate a fine-grained PAT with read access to the certs repo.
#      Build base64("<gh-user>:<PAT>") and store as MATCH_GIT_BASIC_AUTHORIZATION
#      both locally and as a GH Secret.
#
# See: https://docs.fastlane.tools/actions/match/

# REPLACE THIS URL with your actual certs repo before running match.
git_url("https://github.com/CHANGE-ME-ORG/CHANGE-ME-REPO-certs.git")
storage_mode("git")

# Default type for `match` invoked without an arg. Override via subcommand
# (`match appstore`, `match development`, `match mac_installer_distribution`).
type("appstore")

app_identifier(["com.example.helloapp"])

team_id(ENV["FASTLANE_TEAM_ID"])

# Username (Apple ID) is optional with ASC API key auth — match auto-detects
# the API key env vars listed above and uses them for portal access. Uncomment
# only if you fall back to legacy 2FA-cookie auth.
# username(ENV["FASTLANE_APPLE_ID"]) if ENV["FASTLANE_APPLE_ID"]

# LibreSSL (which Ruby on macOS links against) doesn't support AES-GCM auth_data
# in its OpenSSL bindings, breaking match's V2 encryption. Force V1 (AES-256-CBC
# + PBKDF1/MD5 KDF) which works on both LibreSSL and OpenSSL 3.x.
#
# Acceptable security trade-off: certs repo is private, MATCH_PASSWORD is
# 32+ char random, encrypted blobs are useless without it. Re-evaluate when you
# move to a Ruby linked against OpenSSL 3.x (then drop this line). The smoketest
# downstream (indiagrams/ios-macos-smoketest) discovered this constraint.
force_legacy_encryption(true)
